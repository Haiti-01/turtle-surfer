# Vorlage für Build-Setups (Vite, Webpack, ...): Werte in eine .env kopieren
# und per Build-Tool injizieren. Diese statische Seite hat KEINEN Build-Schritt
# und liest die Werte stattdessen aus leaderboard-config.js (siehe README).
#
# Wichtig: Nur der anon/public-Key gehört ins Frontend (durch Row Level
# Security abgesichert). Der service_role-Key bleibt IMMER serverseitig/geheim.
SUPABASE_URL=
SUPABASE_ANON_KEY=
